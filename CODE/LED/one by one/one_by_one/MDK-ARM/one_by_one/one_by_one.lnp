--cpu=Cortex-M4.fp.sp
"one_by_one\startup_stm32f446xx.o"
"one_by_one\main.o"
"one_by_one\stm32f4xx_it.o"
"one_by_one\stm32f4xx_hal_msp.o"
"one_by_one\stm32f4xx_hal_rcc.o"
"one_by_one\stm32f4xx_hal_rcc_ex.o"
