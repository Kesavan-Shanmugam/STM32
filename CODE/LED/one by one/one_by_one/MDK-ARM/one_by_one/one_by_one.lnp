"one_by_one\stm32f4xx_hal_flash_ex.o"
"one_by_one\stm32f4xx_hal_flash_ramfunc.o"
"one_by_one\stm32f4xx_hal_gpio.o"
"one_by_one\stm32f4xx_hal_dma_ex.o"
"one_by_one\stm32f4xx_hal_dma.o"
"one_by_one\stm32f4xx_hal_pwr.o"
