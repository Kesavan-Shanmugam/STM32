--cpu=Cortex-M4.fp.sp
"name print\startup_stm32f446xx.o"
"name print\main.o"
"name print\stm32f4xx_it.o"
"name print\stm32f4xx_hal_msp.o"
"name print\stm32f4xx_hal_rcc.o"
"name print\stm32f4xx_hal_rcc_ex.o"
"name print\stm32f4xx_hal_flash.o"
"name print\stm32f4xx_hal_flash_ex.o"
"name print\stm32f4xx_hal_flash_ramfunc.o"
"name print\stm32f4xx_hal_gpio.o"
"name print\stm32f4xx_hal_dma_ex.o"
"name print\stm32f4xx_hal_dma.o"
"name print\stm32f4xx_hal_pwr.o"
"name print\stm32f4xx_hal_pwr_ex.o"
"name print\stm32f4xx_hal_cortex.o"
"name print\stm32f4xx_hal.o"
"name print\stm32f4xx_hal_exti.o"
"name print\system_stm32f4xx.o"
--strict --scatter "Name print\Name print.sct"
--summary_stderr --info summarysizes --map --load_addr_map_info --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list "Name print.map" -o "Name print\Name print.axf"